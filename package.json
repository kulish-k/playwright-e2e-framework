{
  "name": "playwright-e2e-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright E2E testing framework",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:staging": "cross-env TEST_ENV=staging npx playwright test",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"**/*.{ts,js,json,md}\""
  },
  "keywords": [
    "playwright",
    "e2e",
    "automation",
    "typescript"
  ],
  "author": "Kulish Kulshrestha",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@types/node": "^20.10.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2"
  }
}
